# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mcaforo?schema=public"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="McAforo"

# Auth
AUTH_SECRET="your-auth-secret-min-32-chars-here"

# SMTP Email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@mcaforo.com"

# Flutterwave Payment Gateway
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_WEBHOOK_SECRET="your-webhook-secret-hash"

# mNotify SMS Gateway
MNOTIFY_API_KEY="your-mnotify-api-key"
MNOTIFY_SENDER_ID="McAforo"

# ==========================
# CMS (Sprint 1+ additions)
# ==========================

# Media library (local filesystem driver)
CMS_MEDIA_ROOT="public/uploads"
CMS_MEDIA_MAX_IMAGE_MB="20"
CMS_MEDIA_MAX_VIDEO_MB="100"
CMS_MEDIA_MAX_DOC_MB="50"

# Caching
CMS_CACHE_REVALIDATE_SECONDS="300"

# Preview mode (short-lived JWT used to view drafts)
CMS_PREVIEW_SECRET="generate-with-openssl-rand-hex-32"

# CSRF double-submit token secret
CMS_CSRF_SECRET="generate-with-openssl-rand-hex-32"

# Webhook delivery
CMS_WEBHOOK_RETRIES="5"
CMS_WEBHOOK_TIMEOUT_MS="10000"

# pg-boss (background jobs) uses DATABASE_URL and a separate schema
PGBOSS_SCHEMA="pgboss"

# Public-form rate limits (per IP, per minute)
RATE_LIMIT_CONTACT="5"
RATE_LIMIT_NEWSLETTER="10"
RATE_LIMIT_LOGIN="10"

# Contact submission notifications
CONTACT_SUBMISSION_NOTIFY_EMAIL="hello@mcaforo.com"
