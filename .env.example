# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mcaforo?schema=public"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="McAforo"

# Auth
AUTH_SECRET="your-auth-secret-min-32-chars-here"

# SMTP Email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@mcaforo.com"

# Flutterwave Payment Gateway
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_WEBHOOK_SECRET="your-webhook-secret-hash"

# mNotify SMS Gateway
MNOTIFY_API_KEY="your-mnotify-api-key"
MNOTIFY_SENDER_ID="McAforo"
